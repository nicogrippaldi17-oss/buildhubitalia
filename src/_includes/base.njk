<!DOCTYPE html>
<html lang="{{ lang | default('it') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content" />
  <title>{{ title }} | Build Hub</title>
  <meta name="description" content="{{ description }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <meta property="og:title" content="{{ title }} | Build Hub" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="{{ site.url }}/img/logo-horizontal.svg" />
  <meta property="og:locale" content="{% if lang == "en" %}en_GB{% else %}it_IT{% endif %}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }} | Build Hub" />
  <meta name="twitter:description" content="{{ description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
{% if site.ga_id %}
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="preconnect" href="https://www.google-analytics.com">
{% endif %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="{{ root }}css/style.css" />
  <link rel="icon" href="{{ root }}favicon.svg" type="image/svg+xml" />
{% if site.search_console_meta %}
  <meta name="google-site-verification" content="{{ site.search_console_meta }}" />
{% endif %}
{% if site.ga_id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga_id }}"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag("js",new Date());gtag("config","{{ site.ga_id }}")</script>
{% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Build Hub",
    "url": "{{ site.url }}",
    "description": "{{ description | e("js") }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Catania",
      "addressCountry": "IT"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "{{ contact.phone | e("js") }}",
      "contactType": "customer service",
      "email": "{{ contact.email | e("js") }}"
    }
  }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">{% if lang == "en" %}Skip to content{% else %}Vai al contenuto{% endif %}</a>
  <nav class="webuild-navbar" aria-label="{% if lang == "en" %}Main navigation{% else %}Navigazione principale{% endif %}">
    <div class="navbar-vactor-background">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,90 L1440,90 L1440,0 L890,0 C855,0 845,45 825,55 C805,65 790,65 720,65 C650,65 635,65 615,55 C595,45 585,0 550,0 L0,0 Z" fill="#021164"/>
      </svg>
    </div>
    <div class="navbar-content">
      <div class="nav-links left-links">
{% if lang == "en" %}
        <a href="{{ root }}en/about.html">About Us</a>
        <a href="{{ root }}en/services.html">Services</a>
{% else %}
        <a href="{{ root }}chi-siamo.html">Chi Siamo</a>
        <a href="{{ root }}servizi.html">Servizi</a>
{% endif %}
      </div>
      <div class="nav-logo-capsule">
        <a href="{{ root }}index.html" class="logo-link"><img src="{{ root }}img/logo-horizontal.svg" alt="Build Hub" class="nav-logo-img" /></a>
      </div>
      <div class="nav-links right-links">
{% if lang == "en" %}
        <a href="{{ root }}en/projects.html">Projects</a>
        <a href="{{ root }}en/contact.html">Contact</a>
        <a href="{{ root }}chi-siamo.html" class="nav-lang-switch" title="Italiano">IT</a>
{% else %}
        <a href="{{ root }}progetti.html">Progetti</a>
        <a href="{{ root }}contatti.html">Contatti</a>
        <a href="{{ root }}en/index.html" class="nav-lang-switch" title="English">EN</a>
{% endif %}
      </div>
    </div>
  </nav>

  <main id="main-content">

{{ content | safe }}

  </main>

  <footer class="footer">
    <div class="footer-main">
      <div class="container">
        <div class="footer-grid">
          <div>
            <a href="{{ root }}index.html" class="footer-logo">
              <img src="{{ root }}img/logo-horizontal.svg" alt="Build Hub" />
            </a>
            <div class="footer-socials">
              <a href="https://www.instagram.com/buildhubitalia" target="_blank" rel="noopener" class="social-btn" title="Instagram" aria-label="Instagram">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1"/></svg>
              </a>
              <a href="https://www.facebook.com/profile.php?id=61589930976152" target="_blank" rel="noopener" class="social-btn" title="Facebook" aria-label="Facebook">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            </div>
          </div>
          <div>
            <h4>{% if lang == "en" %}Menu{% else %}Menu{% endif %}</h4>
            <nav class="footer-nav">
{% if lang == "en" %}
              <a href="{{ root }}en/about.html">About Us</a>
              <a href="{{ root }}en/services.html">Services</a>
              <a href="{{ root }}en/projects.html">Projects</a>
              <a href="{{ root }}en/contact.html">Contact</a>
{% else %}
              <a href="{{ root }}chi-siamo.html">Chi Siamo</a>
              <a href="{{ root }}servizi.html">Servizi</a>
              <a href="{{ root }}progetti.html">Progetti</a>
              <a href="{{ root }}contatti.html">Contatti</a>
{% endif %}
            </nav>
          </div>
          <div>
            <h4>{% if lang == "en" %}Contacts{% else %}Contatti{% endif %}</h4>
            <ul class="footer-contacts">
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{{ contact.address }}</span>
              </li>
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                <a href="tel:{{ contact.phone | replace(' ', '') }}" style="color:inherit;text-decoration:none">{{ contact.phone }}</a>
              </li>
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                <a href="tel:{{ contact.phone2 | replace(' ', '') }}" style="color:inherit;text-decoration:none">{{ contact.phone2 }}</a>
              </li>
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:{{ contact.email }}" style="color:inherit;text-decoration:none">{{ contact.email }}</a>
              </li>
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{% if lang == "en" %}Mon-Fri: 9:00 AM - 6:00 PM{% else %}Lun-Ven: 9:00 - 18:00{% endif %}</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <div class="footer-bottom-inner">
          <div class="footer-bottom-links">
{% if lang == "en" %}
            <a href="{{ root }}chi-siamo.html" class="lang-switch" title="Italiano">IT</a>
{% else %}
            <a href="{{ root }}en/index.html" class="lang-switch" title="English">EN</a>
{% endif %}
            <a href="{{ root }}{% if lang == 'en' %}en/{% endif %}privacy.html">{% if lang == "en" %}Privacy Policy{% else %}Privacy Policy{% endif %}</a>
            <a href="{{ root }}{% if lang == 'en' %}en/{% endif %}cookie.html">{% if lang == "en" %}Cookie Policy{% else %}Cookie Policy{% endif %}</a>
          </div>
          <p>&copy; {{ site.year | default(2026) }} Build Hub. {% if lang == "en" %}All rights reserved.{% else %}Tutti i diritti riservati.{% endif %}</p>
        </div>
      </div>
    </div>
  </footer>

  <script src="{{ root }}js/main.js"></script>
</body>
</html>
