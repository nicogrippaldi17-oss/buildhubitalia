---
layout: base.njk
lang: en
title: "Contact"
description: "Contact Build Hub — Request a free consultation for your construction or renovation project in Sicily."
root: "../"
permalink: "/en/contact.html"
---

  <section class="page-hero">
    <div class="page-hero-glow"></div>
    <div class="container">
      <h1>Let's talk about your project</h1>
      <p>Tell us your idea. We will get back to you with an initial analysis within 48 hours.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="contatti-grid">
        <div class="reveal">
          <div id="formSuccess" class="form-success">
            <div class="form-success-icon">
              <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3>Request Sent!</h3>
            <p>Thank you for contacting us. We will review your request and get back to you within 48 hours.</p>
          </div>

          <form id="contactForm" novalidate netlify>
            <input type="hidden" name="form-name" value="Contatti EN" />
            <div id="formError" class="form-error-banner">An error occurred. Please try again later or contact us directly via email.</div>

            <div class="form-row">
              <div class="form-group">
                <label for="nome">Full Name *</label>
                <input type="text" id="nome" name="nome" required placeholder="John Smith" />
                <p class="error-text" style="display:none;"></p>
              </div>
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="john.smith@email.com" />
                <p class="error-text" style="display:none;"></p>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="telefono">Phone</label>
                <input type="tel" id="telefono" name="telefono" placeholder="+39 3XX XXX XXXX" />
              </div>
            </div>

            <div class="form-group">
              <label>Services of interest</label>
              <div class="services-checkboxes">
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="project-management" /> Project Management</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="design-permits" /> Design and Building Permits</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="construction-supervision" /> Construction Supervision</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="site-safety" /> Site Safety</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="cost-management" /> Cost Management</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="energy-efficiency" /> Energy Efficiency</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="private-consulting" /> Private Consulting</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="professional-network" /> Professional Network</label>
              </div>

            <div class="form-group">
              <label for="messaggio">Describe your project *</label>
              <textarea id="messaggio" name="messaggio" required placeholder="Tell us what you want to achieve: type of work, timeline, any constraints you are already aware of..." rows="6"></textarea>
              <p class="error-text" style="display:none;"></p>
            </div>

            <div class="form-group checkbox">
              <input type="checkbox" id="privacy" name="privacy" required />
              <label for="privacy">I have read and accept the privacy policy *</label>
              <p class="error-text" style="display:none;">You must accept the privacy policy</p>
            </div>

            <button type="submit" class="btn btn-primary">
              <span class="btn-text">Request a consultation</span>
              <svg class="spinner" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10" opacity="0.25"/><path d="M4 12a8 8 0 018-8" opacity="0.75"/></svg>
            </button>
          </form>
        </div>

        <div class="contatti-info reveal-right">
          <h3>Contact us directly</h3>
          <div class="contact-badge">
            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            We reply within 24 hours
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div class="text">Catania</div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg></div>
            <div class="text">+39 095 123 4567</div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div class="text">buildhubitalia@gmail.com</div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="text">Mon-Fri: 9:00 AM - 6:00 PM</div>
          </div>
          <div class="contatti-map"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="section bg-surface">
    <div class="container">
      <h2 class="section-title reveal">What happens next</h2>
      <div class="contact-steps reveal-stagger">
        <div class="contact-step">
          <div class="contact-step-bubble">1</div>
          <div class="contact-step-body">
            <h3>Tell us about your project</h3>
            <p>Fill in the form, send us an email or give us a call. We need to understand what you want to achieve, in what context and with what expectations.</p>
          </div>
        </div>
        <div class="contact-step">
          <div class="contact-step-bubble">2</div>
          <div class="contact-step-body">
            <h3>We analyse your request</h3>
            <p>We assess the technical and regulatory context, the challenges and the opportunities. If needed, we schedule a no-obligation meeting to go deeper into the details.</p>
          </div>
        </div>
        <div class="contact-step">
          <div class="contact-step-bubble">3</div>
          <div class="contact-step-body">
            <h3>Receive plan and quote</h3>
            <p>We present you with a clear roadmap, complete with timelines, operational phases and a transparent cost estimate. No surprises, no strings attached.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TERRITORY -->
  <section class="territorio-section">
    <div class="territorio-glow"></div>
    <div class="container">
      <div class="reveal">
        <div class="territorio-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3L17 3l3.5 6.5L19 15l-3 6l-3.5 1L9 19L6 12Z"/></svg></div>
        <h2>Rooted in Sicily</h2>
        <p>We operate throughout Sicily with deep-rooted knowledge of local specificities, the regional regulatory framework and the best construction practices of the Mediterranean area.</p>
      </div>
    </div>
  </section>
