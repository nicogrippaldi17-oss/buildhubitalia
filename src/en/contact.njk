---
layout: base.njk
lang: en
title: "Contact"
description: "Contact Build Hub — Request a free consultation for your construction or renovation project in Sicily."
root: "../"
permalink: "/en/contact.html"
hero_title: "Let's talk about your project"
hero_subtitle: "Tell us your idea. We will get back to you with an initial analysis within 48 hours."
---

  <section class="page-hero">
    <div class="page-hero-glow"></div>
    <div class="container">
      <h1>{{ hero_title }}</h1>
      <p>{{ hero_subtitle }}</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="contatti-grid">
        <div class="reveal">
          <div id="formSuccess" class="form-success">
            <div class="form-success-icon">
              <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3>Request Sent!</h3>
            <p>Thank you for contacting us. We will review your request and get back to you within 48 hours.</p>
          </div>

          <form id="contactForm" novalidate netlify>
            <input type="hidden" name="form-name" value="Contatti EN" />
            <div id="formError" class="form-error-banner">An error occurred. Please try again later or contact us directly via email.</div>

            <div class="form-row">
              <div class="form-group">
                <label for="nome">Full Name *</label>
                <input type="text" id="nome" name="nome" required placeholder="John Smith" />
                <p class="error-text" style="display:none;"></p>
              </div>
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="john.smith@email.com" />
                <p class="error-text" style="display:none;"></p>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="telefono">Phone</label>
                <input type="tel" id="telefono" name="telefono" placeholder="+39 3XX XXX XXXX" />
              </div>
            </div>

            <div class="form-group">
              <label>Services of interest</label>
              <div class="services-checkboxes">
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="project-management" /> Project Management</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="design-permits" /> Design and Building Permits</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="construction-supervision" /> Construction Supervision</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="site-safety" /> Site Safety</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="cost-management" /> Cost Management</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="energy-efficiency" /> Energy Efficiency</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="private-consulting" /> Private Consulting</label>
                <label class="service-checkbox"><input type="checkbox" name="servizi" value="professional-network" /> Professional Network</label>
              </div>
            </div>

            <div class="form-group">
              <label for="messaggio">Describe your project *</label>
              <textarea id="messaggio" name="messaggio" required placeholder="Tell us what you want to achieve: type of work, timeline, any constraints you are already aware of..." rows="6"></textarea>
              <p class="error-text" style="display:none;"></p>
            </div>

            <div class="form-group checkbox">
              <input type="checkbox" id="privacy" name="privacy" required />
              <label for="privacy">I have read and accept the <a href="privacy.html" target="_blank">privacy policy</a> *</label>
              <p class="error-text" style="display:none;">You must accept the privacy policy</p>
            </div>

            <p class="form-disclaimer">Your data will be processed by Build Hub to respond to your request, as described in the <a href="privacy.html" target="_blank">Privacy Policy</a>. Data is retained for a maximum of 24 months. You can request deletion at any time by writing to buildhubitalia@gmail.com.</p>

            <button type="submit" class="btn btn-primary">
              <span class="btn-text">Request a consultation</span>
              <svg class="spinner" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10" opacity="0.25"/><path d="M4 12a8 8 0 018-8" opacity="0.75"/></svg>
            </button>
          </form>
        </div>

        <div class="contatti-info reveal-right">
          <h3>Contact us directly</h3>
          <div class="contact-badge">
            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            We reply within 24 hours
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div class="text">Catania</div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg></div>
            <div class="text"><a href="tel:+393341819317" style="color:inherit;text-decoration:none">+39 334 181 9317</a> / <a href="tel:+393924826908" style="color:inherit;text-decoration:none">+39 392 482 6908</a></div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div class="text"><a href="mailto:buildhubitalia@gmail.com" style="color:inherit;text-decoration:none">buildhubitalia@gmail.com</a></div>
          </div>
          <div class="contatti-info-item">
            <div class="icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="text">Mon-Fri: 9:00 AM - 6:00 PM</div>
          </div>
          <div class="contatti-map" id="contactMap">
            <div class="routing-panel" id="routingPanel">
              <div class="routing-toggle" id="routingToggle">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 11 12 2 21 11"/><polyline points="3 22 12 13 21 22"/></svg>
                <span>Route</span>
                <svg class="routing-chevron" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
              <div class="routing-body" id="routingBody">
                <input type="text" id="searchStart" placeholder="Street, city..." autocomplete="off" />
                <div class="search-results" id="searchResults"></div>
                <input type="text" id="searchEnd" placeholder="Street, city..." autocomplete="off" />
                <div class="search-results" id="searchResultsEnd"></div>
                <button class="btn-clear" id="clearRoute">Clear route</button>
                <div class="route-info" id="routeInfo"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
(function() {
  var map = L.map('contactMap', {
    center: [37.5079, 15.0830],
    zoom: 13,
    scrollWheelZoom: false
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
    subdomains: 'abcd',
    maxZoom: 20
  }).addTo(map);

  var officeIcon = L.divIcon({
    html: '<svg viewBox="0 0 40 40" width="28" height="40"><circle cx="20" cy="12" r="8" fill="#F59E0B" stroke="#fff" stroke-width="2"/><path d="M20 20L20 38" stroke="#F59E0B" stroke-width="3" stroke-linecap="round"/><circle cx="20" cy="38" r="3" fill="#F59E0B"/></svg>',
    iconSize: [28, 40],
    iconAnchor: [14, 40],
    popupAnchor: [0, -40],
    className: ''
  });

  var office = L.marker([37.5079, 15.0830], { icon: officeIcon }).addTo(map);
  office.bindPopup('<h4>Build Hub</h4><p>Catania</p>');

  document.getElementById('routingToggle').addEventListener('click', function() {
    document.getElementById('routingPanel').classList.toggle('open');
  });

  function openRouting() {
    document.getElementById('routingPanel').classList.add('open');
  }

  var waypoints = [];
  var routeLine = null;

  function nominatimSearch(query, callback) {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', 'https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(query) + '&limit=8&addressdetails=1');
    xhr.onload = function() {
      if (xhr.status === 200) callback(JSON.parse(xhr.responseText));
    };
    xhr.send();
  }

  function getRoute(startLon, startLat, endLon, endLat) {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', 'https://router.project-osrm.org/route/v1/driving/' + startLon + ',' + startLat + ';' + endLon + ',' + endLat + '?overview=full&geometries=geojson');
    xhr.onload = function() {
      if (xhr.status === 200) {
        var data = JSON.parse(xhr.responseText);
        if (data.code === 'Ok' && data.routes.length > 0) {
          var route = data.routes[0];
          var coords = route.geometry.coordinates.map(function(c) { return [c[1], c[0]]; });
          if (routeLine) map.removeLayer(routeLine);
          routeLine = L.polyline(coords, { color: '#F59E0B', weight: 4, opacity: 0.8 }).addTo(map);
          map.fitBounds(routeLine.getBounds().pad(0.1));
          var dist = (route.distance / 1000).toFixed(1);
          var dur = Math.round(route.duration / 60);
          document.getElementById('routeInfo').innerHTML = '<strong>' + dist + ' km</strong> &middot; ' + dur + ' min';
          openRouting();
        }
      }
    };
    xhr.send();
  }

  var searchTimerStart;
  var searchTimerEnd;
  var searchInput = document.getElementById('searchStart');
  var searchResults = document.getElementById('searchResults');

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimerStart);
      var q = this.value.trim();
      if (q.length < 3) { searchResults.style.display = 'none'; return; }
      searchTimerStart = setTimeout(function() {
        nominatimSearch(q, function(results) {
          searchResults.innerHTML = '';
          if (results.length === 0) { searchResults.style.display = 'none'; return; }
          searchResults.style.display = 'block';
          results.forEach(function(r) {
            var d = document.createElement('div');
            var parts = r.display_name.split(',');
            d.textContent = parts.slice(0, 3).join(',').trim();
            d.addEventListener('click', function() {
              searchInput.value = parts.slice(0, 2).join(',').trim();
              searchResults.style.display = 'none';
              waypoints[0] = [parseFloat(r.lat), parseFloat(r.lon)];
              if (waypoints[0] && waypoints[1]) getRoute(waypoints[0][1], waypoints[0][0], waypoints[1][1], waypoints[1][0]);
            });
            searchResults.appendChild(d);
          });
        });
      }, 300);
    });
  }

  var searchInputEnd = document.getElementById('searchEnd');
  var searchResultsEnd = document.getElementById('searchResultsEnd');

  if (searchInputEnd) {
    searchInputEnd.addEventListener('input', function() {
      clearTimeout(searchTimerEnd);
      var q = this.value.trim();
      if (q.length < 3) { searchResultsEnd.style.display = 'none'; return; }
      searchTimerEnd = setTimeout(function() {
        nominatimSearch(q, function(results) {
          searchResultsEnd.innerHTML = '';
          if (results.length === 0) { searchResultsEnd.style.display = 'none'; return; }
          searchResultsEnd.style.display = 'block';
          results.forEach(function(r) {
            var d = document.createElement('div');
            var parts = r.display_name.split(',');
            d.textContent = parts.slice(0, 3).join(',').trim();
            d.addEventListener('click', function() {
              searchInputEnd.value = parts.slice(0, 2).join(',').trim();
              searchResultsEnd.style.display = 'none';
              waypoints[1] = [parseFloat(r.lat), parseFloat(r.lon)];
              if (waypoints[0] && waypoints[1]) getRoute(waypoints[0][1], waypoints[0][0], waypoints[1][1], waypoints[1][0]);
            });
            searchResultsEnd.appendChild(d);
          });
        });
      }, 300);
    });
  }

  map.on('click', function(e) {
    if (!waypoints[0]) {
      waypoints[0] = [e.latlng.lat, e.latlng.lng];
      document.getElementById('searchStart').value = e.latlng.lat.toFixed(4) + ', ' + e.latlng.lng.toFixed(4);
    } else if (!waypoints[1]) {
      waypoints[1] = [e.latlng.lat, e.latlng.lng];
      document.getElementById('searchEnd').value = e.latlng.lat.toFixed(4) + ', ' + e.latlng.lng.toFixed(4);
      getRoute(waypoints[0][1], waypoints[0][0], waypoints[1][1], waypoints[1][0]);
    }
  });

  document.getElementById('clearRoute').addEventListener('click', function() {
    waypoints = [];
    if (routeLine) { map.removeLayer(routeLine); routeLine = null; }
    document.getElementById('searchStart').value = '';
    document.getElementById('searchEnd').value = '';
    document.getElementById('routeInfo').innerHTML = '';
    map.setView([37.5079, 15.0830], 13);
  });

  map.on('mouseenter', function() { map.scrollWheelZoom.enable(); });
  map.on('mouseleave', function() { map.scrollWheelZoom.disable(); });
})();
</script>

  <!-- WHAT HAPPENS NEXT -->
  <section class="section bg-surface">
    <div class="container">
      <h2 class="section-title reveal">What happens next</h2>
      <div class="contact-steps reveal-stagger">
        <div class="contact-step">
          <div class="contact-step-bubble">1</div>
          <div class="contact-step-body">
            <h3>Tell us about your project</h3>
            <p>Fill in the form, send us an email or give us a call. We need to understand what you want to achieve, in what context and with what expectations.</p>
          </div>
        </div>
        <div class="contact-step">
          <div class="contact-step-bubble">2</div>
          <div class="contact-step-body">
            <h3>We analyse your request</h3>
            <p>We assess the technical and regulatory context, the challenges and the opportunities. If needed, we schedule a no-obligation meeting to go deeper into the details.</p>
          </div>
        </div>
        <div class="contact-step">
          <div class="contact-step-bubble">3</div>
          <div class="contact-step-body">
            <h3>Receive plan and quote</h3>
            <p>We present you with a clear roadmap, complete with timelines, operational phases and a transparent cost estimate. No surprises, no strings attached.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

